{
  "name": "postmanclone",
  "version": "0.1.0",
  "description": "Postman-like API client for Java Spring developers",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:helper": "cd helper && ./gradlew shadowJar",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:roundtrip": "vitest run tests/round-trip.test.ts"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "5.90.3",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "undici": "^7.27.0",
    "zod": "4.0.1",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.postmanclone.app",
    "productName": "PostmanClone",
    "asar": true,
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/helper",
        "to": "helper"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
